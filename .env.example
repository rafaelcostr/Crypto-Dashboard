# Segurança (obrigatório em produção, mín. 32 caracteres)
AUTH_JWT_SECRET=sua-chave-secreta-longa-aqui

# URL pública do app (links de confirmação de e-mail)
APP_URL=http://localhost:5173

# Seu e-mail = único administrador (pode separar vários com vírgula)
ADMIN_EMAIL=seu-email@gmail.com

# Opcional: redefine senha via API (Vercel). Remova depois de usar.
# POST /api/auth/reset-password-key  { email, password, resetKey }
# PASSWORD_RESET_KEY=uma-chave-longa-secreta-min-16-chars

# Opcional: caminho do auth-store (padrão: data/ local, /tmp na Vercel)
# AUTH_STORE_PATH=/caminho/gravavel/auth-store.json

# CoinGecko Demo API key (evita 403 na Vercel) — https://www.coingecko.com/en/api
# COINGECKO_API_KEY=sua-chave-demo

# SMTP para envio de e-mails (Gmail, Outlook, Resend SMTP, etc.)
# Sem SMTP, em desenvolvimento o link aparece na tela após o cadastro
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Crypto Dashboard <seu-email@gmail.com>
